# Server
PORT=3000
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# AWS (Bedrock for OCR + SES for email)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_OCR_MODEL=qwen.qwen3-vl-235b-a22b
BEDROCK_TEXT_MODEL=openai.gpt-oss-120b-1:0

# OpenRouter (PDF-to-HTML pipeline)
OPENROUTER_API_KEY=
OPENROUTER_PDF_MODEL=google/gemini-3-flash-preview

# Admin seed (created on first run if not exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Email notifications (AWS SES)
SES_FROM_EMAIL=noreply@example.com
APP_URL=http://localhost:5173

# Production only
# TRUST_PROXY=true
# COOKIE_SECURE=true
